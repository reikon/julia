# Public, non-secret config for the Docusaurus wiki. Docusaurus does not auto-load
# .env; on Vercel set these in the project dashboard. Not secrets.

# The wiki's own public origin (Docusaurus `url`). Dev fallback: localhost:3001.
SITE_URL=

# The landing site, used for the navbar "Home" link. Dev fallback: localhost:3000.
WEB_URL=
