# Public (non-secret) PRODUCTION values for the wiki.
# NOTE: Docusaurus does not auto-load .env files. On Vercel, set these in the docs
# project's dashboard env vars (they become process.env at build). This file documents
# the intended values. Local dev uses the localhost fallbacks in docusaurus.config.ts.

# The wiki's own canonical origin.
SITE_URL=https://doc.knowpeptide.com
# The landing site, used for the navbar "Home" link.
WEB_URL=https://www.knowpeptide.com
