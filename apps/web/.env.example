# Public, non-secret config for the web app. Copy to .env for committed defaults
# or .env.local for machine-specific overrides. None of these are secrets.

# Origin of the deployed Docusaurus wiki. The web app rewrites /doc/* to it.
# Local dev defaults to http://localhost:3001 if unset (see next.config.ts).
DOCS_URL=

# Public origin of the web app itself. Used for canonical URLs and OG/Twitter cards.
# Local dev defaults to http://localhost:3000 if unset.
SITE_URL=
