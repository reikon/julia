# Public (non-secret) PRODUCTION defaults. Next.js loads .env.production only for
# `next build` / `next start`, NOT for `next dev`, so local dev keeps the localhost
# fallbacks in next.config.ts. Vercel dashboard env vars override these at build time.

DOCS_URL=https://peptidia-docs.vercel.app
SITE_URL=https://peptidia-web.vercel.app
